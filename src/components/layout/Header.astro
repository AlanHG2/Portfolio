44-.515.633-38.84.64-85.16l.012-84.215-2.773-2.062c-1.523-1.133-6.996-4.293-12.156-7.02-21.328-11.27-72.863-39.656-77.203-42.527-2.57-1.7-5.16-3.09-5.758-3.09-.875 0-1.086 26.977-1.086 138.656"
            ></path>
          </svg>
        </a>
      </div>

      <!-- Navegación de Escritorio -->
      <nav class="desktop-nav" aria-label="Navegación principal de escritorio">
        <ul class="nav-list desktop-nav-list">
          {
            navLinks.map((link) => (
              <li class="nav-item">
                <a href={link.href} class="nav-link">
                  {link.label}
                </a>
              </li>
            ))
          }
          <li class="nav-item">
            <ModeToggle client:load />
          </li>
        </ul>
      </nav>
    </div>

    <div class="header-right">
      <div class="contact-container">
        <button
          id="header-contact-btn"
          type="button"
          class="contact-link"
          aria-haspopup="dialog"
        >Contactar</button>
      </div>

      <!-- Botón de menú móvil -->
      <label for="mobile-menu-toggle" class="mobile-menu-btn">
        <svg
          class="icon-menu"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
        <svg
          class="icon-close"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </label>
    </div>
  </div>
</header>

<!-- Navegación Móvil (Fuera del header para evitar el bug del backdrop-filter padre) -->
<nav
  class="mobile-nav"
  id="mobile-menu"
  aria-label="Navegación principal móvil"
>
  <ul class="nav-list">
    {
      navLinks.map((link) => (
        <li class="nav-item">
          <a href={link.href} class="nav-link mobile-nav-link">
            {link.label}
          </a>
        </li>
      ))
    }
    <li class="nav-item">
      <ModeToggle client:load />
    </li>
  </ul>
</nav>

<script>
  const initMobileMenu = () => {
    const toggle = document.getElementById(
      "mobile-menu-toggle",
    ) as HTMLInputElement | null;
    const nav = document.getElementById("mobile-menu");
    const links = document.querySelectorAll(".mobile-nav-link");

    if (!toggle || !nav) return;

    // Cerrar al hacer clic en un enlace
    links.forEach((link) => {
      link.addEventListener("click", () => {
        toggle.checked = false;
      });
    });

    // Cerrar al hacer clic en la parte negra (cualquier elemento que no sea un enlace)
    nav.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).tagName !== "A") {
        toggle.checked = false;
      }
    });
  };

  initMobileMenu();
  document.addEventListener("astro:page-load", initMobileMenu);

  const initContactBtn = () => {
    const btn = document.getElementById("header-contact-btn");
    btn?.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("open-contact-modal"));
    });
  };

  initContactBtn();
  document.addEventListener("astro:page-load", initContactBtn);
</script>
