---
import SectionTitle from "@/components/ui/SectionTitle.astro";

const skills = [
	"Desarrollo Web",
	"Diseño de Sistemas",
	"UI/UX",
	"Automatización de Procesos",
	"Minería de Datos",
	"Prototipado",
	"Liderazgo Técnico",
	"Resolución de Problemas",
	"Comunicación Efectiva",
];

const technologies = [
	"JavaScript / TypeScript",
	"Java",
	"Python",
	"SQL",
	"NoSQL",
	"ORM",
	"Spring Boot",
	"React",
	"Next.js",
	"Astro",
	"Tailwind CSS",
	"Git & GitHub",
	"Docker",
	"Google Cloud",
];
---

<section id="about" class="about-section">
  <SectionTitle title="Sobre Mí" />
  <div class="about-container">
    <div class="about-content reveal">
      <p class="about-text">
        Desarrollador de software <span class="font-bold"
          >orgullosamente mexicano</span
        >. Licenciado en Ciencias Computacionales por parte del Instituto de
        Ciencias Básicas e Ingeniería de la Universidad Autónoma del Estado de
        Hidalgo. Especializado en crear experiencias digitales rápidas,
        accesibles y <span class="text-primary"
          >estéticamente excepcionales</span
        >.
      </p>
    </div>
    <div class="about-skills reveal">
      <h3 class="section-title">HABILIDADES</h3>
      <ul class="skills-list">
        {
          skills.map((skill, i) => (
            <li
              class="skill-badge reveal-stagger"
              style={`--stagger-delay: ${i * 50}ms`}
            >
              {skill}
            </li>
          ))
        }
      </ul>

      <h3 class="section-title">TECNOLOGÍAS</h3>
      <ul class="skills-list">
        {
          technologies.map((tech, i) => (
            <li
              class="skill-badge reveal-stagger"
              style={`--stagger-delay: ${i * 40}ms`}
            >
              {tech}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
